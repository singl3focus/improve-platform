# MVP local stack — copy to .env in repo root, then: docker compose -f build/docker-compose.yml up -d --build
# Required
POSTGRES_USER=improve
POSTGRES_PASSWORD=improve
POSTGRES_DB=improve
JWT_SECRET=change-me-to-a-random-secret

# Optional (defaults shown)
POSTGRES_PORT=5432
BACKEND_PORT=8080
FRONTEND_PORT=3000
LOG_LEVEL=info

# Telegram notifications (optional; leave TELEGRAM_BOT_TOKEN empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_HOUR=9
NOTIFY_MINUTE=0
NOTIFY_TIMEZONE=UTC
